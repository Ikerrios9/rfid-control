# Copia este fichero a .env y rellena los valores reales.
# .env está en .gitignore — no se sube al repo.

# External Database URL de Render (la del Postgres, NO la del web service).
# Solo se usa en la Pi / Docker local para mandar datos a la nube cada 20 min.
# Render dashboard -> tu Postgres -> Connect -> External Database URL.
CLOUD_DATABASE_URL=postgresql://USER:PASSWORD@dpg-XXXX-a.frankfurt-postgres.render.com/DBNAME
